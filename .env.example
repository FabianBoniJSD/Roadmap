# =============================================================================
# Next.js Roadmap - Environment Configuration (Current)
# =============================================================================
# Copy to .env.local (development) or .env.production (server).
# Do not commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment / Runtime
# -----------------------------------------------------------------------------
# Used for SharePoint URL and basePath selection.
# Recommended values: development | production
NEXT_PUBLIC_DEPLOYMENT_ENV=development
NODE_ENV=development

# Base paths (leave empty when hosted at root).
NEXT_PUBLIC_BASE_PATH_DEV=
NEXT_PUBLIC_BASE_PATH_PROD=/roadmap

# SharePoint web URL per deployment environment.
NEXT_PUBLIC_SHAREPOINT_SITE_URL_DEV=https://your-sharepoint-dev.domain.com/sites/yoursite
NEXT_PUBLIC_SHAREPOINT_SITE_URL_PROD=https://your-sharepoint-prod.domain.com/sites/yoursite

# Optional server-side absolute app URL for internal fetch calls.
INTERNAL_API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE=""
NEXT_PUBLIC_MAINTENANCE_TIME="30"
# -----------------------------------------------------------------------------
# Database / Instance
# -----------------------------------------------------------------------------
DATABASE_URL="file:./prisma/dev.db"

# Optional: cache TTL for instance config resolution (milliseconds).
INSTANCE_CACHE_TTL_MS=30000

# Optional: Prisma logging detail (set to debug for SQL query logs).
PRISMA_LOG_LEVEL=error

# -----------------------------------------------------------------------------
# SharePoint Authentication (Current Standard)
# -----------------------------------------------------------------------------
# Kerberos service account used by /api/sharepoint proxy.
# Use DOMAIN\username format.
SP_KERBEROS_SERVICE_USER=
SP_KERBEROS_SERVICE_PASSWORD=

# Optional legacy credential fallback (kept for compatibility paths/tools).
SP_USERNAME=
SP_PASSWORD=
USER_NAME=
USER_PASSWORD=

# Optional domain hint for certain on-prem parsing paths.
SP_ONPREM_DOMAIN=

# Optional legacy auth mode overrides (normally not required).
# If unset, runtime defaults to kerberos.
# SP_STRATEGY=kerberos
# NEXT_PUBLIC_SP_AUTH_MODE=kerberos

# -----------------------------------------------------------------------------
# SharePoint Proxy Behavior / Diagnostics
# -----------------------------------------------------------------------------
# Enable verbose SharePoint proxy logs.
SP_PROXY_DEBUG=false

# Keep in-memory curl GET cache for N seconds.
SP_CURL_CACHE_SECONDS=60

# If kerberos curl call returns 401, allow NTLM retry.
# Set to false only for strict debugging.
SP_CURL_NTLM_FALLBACK=true

# Optional debug-only delay before NTLM fallback is attempted.
# In normal runtime the proxy now forces immediate fallback after the first 401.
# Raise this only temporarily together with SP_PROXY_DEBUG=true.
# SP_KERBEROS_NTLM_FALLBACK_AFTER_401S=1

# Allow fallback from curl path to fetch path when curl fails.
SP_CURL_FALLBACK_TO_FETCH=false

# Enable curl verbose output in proxy logs.
SP_CURL_VERBOSE=false

# Decode %24select -> $select in forwarded SharePoint query strings.
SP_DECODE_DOLLAR=false

# Disable undici dispatcher usage for fetch fallback troubleshooting.
SP_DISABLE_DISPATCHER=false

# Disable auth-related cache decisions in instance config.
SP_AUTH_NO_CACHE=false

# -----------------------------------------------------------------------------
# TLS / Proxy Networking
# -----------------------------------------------------------------------------
# Allow invalid/self-signed certificates (development only).
SP_ALLOW_SELF_SIGNED=false

# Additional insecure TLS fallback switch (legacy compatibility).
SP_TLS_FALLBACK_INSECURE=false

# Optional path to custom trusted CA certificate file.
SP_TRUSTED_CA_PATH=

# Optional custom proxy agent for outbound requests.
SP_CUSTOM_PROXY_AGENT=false

# Optional outbound proxy settings.
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port

# Optional Node TLS overrides (advanced, use with caution).
# NODE_EXTRA_CA_CERTS=
# NODE_TLS_REJECT_UNAUTHORIZED=0

# -----------------------------------------------------------------------------
# Admin Auth / Public API
# -----------------------------------------------------------------------------
# Required for JWT-based admin session tokens.
# Use a long random secret (>= 32 chars).
JWT_SECRET=your-secure-random-string-here-minimum-32-characters
JWT_EXPIRES_IN=24h

# Optional API keys for /api/public/projects (comma-separated).
PUBLIC_PROJECTS_API_KEYS=

# -----------------------------------------------------------------------------
# Microsoft Entra ID SSO (Optional)
# -----------------------------------------------------------------------------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=

# Admin allow-list (comma-separated UPN/email).
ENTRA_ADMIN_UPNS=

# Development bypass: allow any Entra user as admin.
ENTRA_ALLOW_ALL=false

# Auto-redirect to Entra login on /admin/login.
NEXT_PUBLIC_ENTRA_AUTO_LOGIN=false

# -----------------------------------------------------------------------------
# UI / App Debug
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG_AUTH=false
NEXT_PUBLIC_DEBUG_EXPOSE=0

# Show maintenance banner to all users.
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE=Roadmap is currently in maintenance mode.

# Silence Next.js config log lines during build/start.
SUPPRESS_CONFIG_LOG=0

# Disable telemetry in CI/servers.
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Super Admin Scope (Optional)
# -----------------------------------------------------------------------------
# Limit super admin checks to specific instances.
# Use comma-separated list or "all" / "*".
SUPERADMIN_INSTANCE_SLUGS=
SUPERADMIN_INSTANCE_SLUG=

# =============================================================================
# Security Notes
# =============================================================================
# 1) Never commit .env.local / .env.production.
# 2) Use dedicated service accounts with least privilege.
# 3) Rotate SP and JWT secrets regularly.
# 4) Prefer external secret stores for production.
# =============================================================================
